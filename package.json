{
  "name": "doit",
  "private": true,
  "version": "1.0.1",
  "description": "A polished Electron Todo desktop application",
  "author": "Prashant A.",
  "main": "dist-electron/main/electronConfig.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json && vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "preview": "vite preview",
    "package": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "lineicons": "^1.3.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
  "electron": "^35.7.5",
  "electron-builder": "^26.8.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.5.3",
    "vite": "^6.4.1",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.5",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.doit.app",
    "productName": "DoIt",
    "icon": "public/icon",
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "!**/*.map",
      "!**/*.ts",
      "!**/*.tsx",
      "!**/*.md",
      "!**/*.log",
      "!**/src{,/**}",
      "!**/scripts{,/**}",
      "!**/.vscode{,/**}",
      "!**/.github{,/**}",
      "!**/release{,/**}"
    ],
    "asar": true,
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icon.png"
    }
  }
}
